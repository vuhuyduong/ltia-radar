# ============================================
# LTIA Radar — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# For production, configure these in Railway / Vercel dashboards.

# --- MongoDB ---
# Local development (Docker):
# MONGODB_URI=mongodb://mongodb:27017
# Production (MongoDB Atlas):
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DATABASE=ltia_radar

# --- Google Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Telegram Alerting ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Production: add your Vercel domain
BACKEND_CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]

# --- Frontend (set in Vercel dashboard for production) ---
# Local:
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production example:
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app

# --- Crawler ---
CRAWLER_INTERVAL_MINUTES=60
CRAWLER_MAX_CONCURRENT=5
LLM_RATE_LIMIT_PER_MINUTE=10
